<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- ================= HEADER ================= -->

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="#EDEDED"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txt_movie_name"
            android:text="Oppenheimer"
            android:textSize="22sp"
            android:textColor="#000"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:text="+13"
                android:textColor="#fff"
                android:textSize="12sp"
                android:padding="6dp"
                android:background="@drawable/bg_green_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="EN"
                android:textSize="12sp"
                android:textColor="#000"
                android:layout_marginStart="6dp"
                android:padding="6dp"
                android:background="@drawable/bg_gray_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="ScreenX"
                android:textSize="12sp"
                android:textColor="#666"
                android:layout_marginStart="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ================= SCREEN GLOW ================= -->

    <ImageView
        android:id="@+id/screenGlow"
        android:layout_width="300dp"
        android:layout_height="80dp"
        android:src="@drawable/screen_glow"
        android:scaleType="fitXY"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- ================= SEATS ================= -->

    <LinearLayout
        android:id="@+id/seatsWrapper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/screenGlow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <GridLayout
            android:id="@+id/gridLeft"
            android:columnCount="4"
            android:rowCount="6"
            android:layout_marginEnd="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <GridLayout
            android:id="@+id/gridRight"
            android:columnCount="4"
            android:rowCount="6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ================= LEGEND ================= -->

    <LinearLayout
        android:id="@+id/legend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/seatsWrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View style="@style/legendDotGray"/>
        <TextView
            style="@style/legendText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booked"/>

        <View style="@style/legendDotGreen"/>
        <TextView style="@style/legendText" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Yours"/>

        <View style="@style/legendDotWhite"/>
        <TextView style="@style/legendText" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Available"/>
    </LinearLayout>

    <TextView
        android:id="@+id/txtTotals"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selected: 0 | Ticket Total: $0"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/legend"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= BOTTOM PANEL ================= -->

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="@drawable/bg_bottom_panel"
        android:padding="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnBookSkip"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:text="Book Seats"
            android:textColor="#fff"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_red"/>

        <Button
            android:id="@+id/btnProceedSnacks"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:text="Proceed to Snacks"
            android:textColor="#000"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_white"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
