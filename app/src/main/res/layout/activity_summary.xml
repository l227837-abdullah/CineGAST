<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- ================= HEADER ================= -->

    <TextView
        android:id="@+id/header_title"
        android:text="Booking Details"
        android:textColor="#fff"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- ================= MOVIE CARD ================= -->

    <LinearLayout
        android:id="@+id/movieCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="22dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/header_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="70dp"
            android:layout_height="90dp"
            android:background="#aaa"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtMovieName"
                android:text="Oppenheimer"
                android:textColor="#fff"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="+13"
                    android:textColor="#fff"
                    android:background="@drawable/bg_green_tag"
                    android:padding="4dp"
                    android:textSize="11sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="EN"
                    android:textColor="#fff"
                    android:background="@drawable/bg_gray_tag"
                    android:padding="4dp"
                    android:textSize="11sp"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Dolby Atmos"
                    android:textColor="#aaa"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#222"
        app:layout_constraintTop_toBottomOf="@id/movieCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= TICKETS ================= -->

    <TextView
        android:id="@+id/txtTickets"
        android:text="Tickets"
        android:textColor="#fff"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/movieCard"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txtTicketList"
        android:text="Row E Seat 5 — 16 USD\nRow E Seat 6 — 16 USD\nRow E Seat 7 — 16 USD"
        android:textColor="#aaa"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtTickets"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#222"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtTicketList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= SNACKS ================= -->

    <TextView
        android:id="@+id/txtSnacks"
        android:text="Snacks"
        android:textColor="#fff"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/txtTicketList"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txtSnackList"
        android:text="x2 Medium Popcorn — 16 USD\nx1 Caramel Popcorn — 16 USD"
        android:textColor="#aaa"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtSnacks"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#222"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtSnackList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= TOTAL ================= -->

    <LinearLayout
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtSnackList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="0dp"
        android:layout_height="wrap_content">

        <TextView
            android:text="TOTAL"
            android:textColor="#fff"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtTotalPrice"
            android:text="59.98 USD"
            android:textColor="#fff"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ================= BOTTOM BUTTON PANEL ================= -->

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="@drawable/bg_bottom_panel"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSend"
            android:text="Send Ticket"
            android:textColor="#fff"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_red"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
